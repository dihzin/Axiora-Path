.gitignore profissional (monorepo Python + Node + Docker)
# =========================================================
# OS FILES
# =========================================================
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# =========================================================
# EDITORS / IDE
# =========================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.iml

# =========================================================
# TEMP / CACHE
# =========================================================
.tmp/
tmp/
temp/
*.tmp
*.temp
*.cache
.cache/
*.swp
*.swo
*.bak

# =========================================================
# ENVIRONMENT VARIABLES
# =========================================================
.env
.env.*
!.env.example
!.env.sample

# =========================================================
# PYTHON
# =========================================================

# Bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Python tools
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# =========================================================
# NODE / JAVASCRIPT
# =========================================================

# Dependencies
node_modules/

# Package managers
.pnpm-store/
.npm/
.yarn/

# Next.js
.next/
out/

# Builds
dist/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# =========================================================
# DATABASES
# =========================================================
*.sqlite
*.sqlite3
*.db

# =========================================================
# DOCKER
# =========================================================
docker-data/
docker-volumes/
*.pid

# =========================================================
# TEST / COVERAGE
# =========================================================
coverage/
.nyc_output/

# =========================================================
# SECURITY / SECRETS
# =========================================================
*.pem
*.key
*.crt
*.p12
*.pfx

# =========================================================
# BACKUPS
# =========================================================
*.backup
*.old
*.dump

# =========================================================
# PROJECT SPECIFIC (Axiora)
# =========================================================

# Python packaging metadata
apps/api/*.egg-info/

# Local scripts
scripts/local/
bootstrap_local.ps1

# Temporary project folders
.tmp/

# Local database
apps/api/*.db
apps/api/*.sqlite

# Local schema comparison artifacts
tmp_*schema.sql
tmp_*schema*.sql
